<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6000000"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Temps écoulé"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="L'appareil est verrouillé par FamilyGuard."
            android:textColor="#BBBBBB"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="32dp" />

        <!-- PIN Input Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entrez le code PIN pour déverrouiller"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginTop="40dp" />

        <EditText
            android:id="@+id/pinInput"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:hint="● ● ● ●"
            android:textAlignment="center"
            android:textSize="24sp"
            android:letterSpacing="0.3"
            android:background="@android:color/transparent"
            android:paddingBottom="8dp" />

        <!-- Simple underline -->
        <View
            android:layout_width="200dp"
            android:layout_height="2dp"
            android:background="#4444FF" />

        <TextView
            android:id="@+id/pinError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF4444"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/unlockButton"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:text="Déverrouiller"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:backgroundTint="#2563EB" />

    </LinearLayout>

</FrameLayout>
