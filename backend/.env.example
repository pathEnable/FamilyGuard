# =======================================================================
# TEMPLATE D'ENVIRONNEMENT (Copiez ceci dans Render ou dans votre .env)
# =======================================================================

# ── Base de Données ──
# Mettez ici l'URL de votre base de données Neon
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ── Sécurité ──
SECRET_KEY=replace_this_with_a_long_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ── CORS (Production) ──
# Mettez 'true' en production pour autoriser l'app Mobile et Web à s'y connecter
ALLOW_ALL_CORS=true

# ── SMTP (Rapports hebdomadaires) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application
SMTP_FROM_NAME=FamilyGuard
SMTP_FROM_EMAIL=votre.email@gmail.com
